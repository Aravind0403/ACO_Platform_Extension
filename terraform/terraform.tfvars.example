# Copy this to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — never commit it.

project_id = "your-gcp-project-id"
region     = "us-central1"
zone       = "us-central1-a"

cluster_name = "aco-platform"

# Keep at 1 for demo/cost control
cpu_node_count  = 2
t4_node_count   = 1
a10_node_count  = 1
v100_node_count = 1
p100_node_count = 1
